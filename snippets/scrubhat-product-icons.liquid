{% comment %}
  Icon USP list for the product page (rendered via a Custom Liquid block).
  Edit the rows below to change icons or text.
  The washing + elasticated-back rows are scrub-hat specific and are hidden
  automatically when the product is a pocket organiser (title or type
  contains "pocket").
{% endcomment %}
{%- assign sh_title = product.title | downcase -%}
{%- assign sh_type = product.type | downcase -%}
{%- assign is_pocket = false -%}
{%- if sh_title contains 'pocket' or sh_type contains 'pocket' -%}
  {%- assign is_pocket = true -%}
{%- endif -%}
<div class="scrubhat-product-icons">
  <div class="scrubhat-product-icons__row">
    <img src="{{ 'scrubhat-icon-hands.svg' | asset_url }}" alt="" aria-hidden="true" width="30" height="30">
    <p>Handmade by our small business in Surrey</p>
  </div>
  <div class="scrubhat-product-icons__row">
    <img src="{{ 'scrubhat-icon-feather.svg' | asset_url }}" alt="" aria-hidden="true" width="30" height="30">
    <p>Lightweight, comfortable and breathable fabric</p>
  </div>
  <div class="scrubhat-product-icons__row">
    <img src="{{ 'scrubhat-icon-globe.svg' | asset_url }}" alt="" aria-hidden="true" width="30" height="30">
    <p>100% ethically sourced cotton</p>
  </div>
  {%- unless is_pocket -%}
    <div class="scrubhat-product-icons__row">
      <img src="{{ 'scrubhat-icon-washing.svg' | asset_url }}" alt="" aria-hidden="true" width="28" height="34">
      <p>Washable at 40°C and hang dry</p>
    </div>
    <p class="scrubhat-product-icons__note">
      Easy to put on with an elasticated back to tuck up long hair and a tie to secure (perfect fit for both men and
      women)
    </p>
  {%- endunless -%}
</div>
