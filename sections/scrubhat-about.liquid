{{ 'scrubhat.css' | asset_url | stylesheet_tag }}

{% style %}
  .scrubhat-about {
    font-family: var(--sh-font-body);
    color: var(--sh-text);
  }
  .scrubhat-about__eyebrow {
    font-family: var(--sh-font-body);
    font-size: 1.6rem;
    letter-spacing: 0.02em;
    color: #43786c;
    margin: 0 0 1.2rem;
  }
  /* --- Hero --- */
  .scrubhat-about__hero {
    background: #d3f5f1;
    padding: 7rem 2rem;
  }
  .scrubhat-about__hero-inner {
    max-width: var(--page-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 5rem;
    align-items: center;
    padding: 0 3rem;
  }
  .scrubhat-about__hero h1 {
    font-family: var(--sh-font-heading) !important;
    font-size: 5.6rem;
    line-height: 1.15;
    margin: 0 0 2rem;
    color: var(--sh-text);
  }
  .scrubhat-about__hero h1 em {
    font-style: normal;
    color: #43786c;
  }
  .scrubhat-about__hero-text {
    font-size: 1.8rem;
    line-height: 1.6;
    margin: 0 0 3rem;
    max-width: 44rem;
  }
  .scrubhat-about__photo-frame {
    position: relative;
    justify-self: end;
    width: 100%;
    max-width: 380px;
  }
  .scrubhat-about__photo-frame::before {
    content: '';
    position: absolute;
    inset: -14px -14px 14px 14px;
    background: var(--sh-pink);
    border: 2px solid var(--sh-ink);
    border-radius: 20px;
    z-index: 0;
  }
  .scrubhat-about__photo-frame img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: auto;
    display: block;
    border: 2px solid var(--sh-ink);
    border-radius: 20px;
    object-fit: cover;
  }
  /* --- Story --- */
  .scrubhat-about__story {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 8rem 5rem;
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 6rem;
    align-items: start;
  }
  .scrubhat-about__story-photo img {
    width: 100%;
    height: auto;
    border: 2px solid var(--sh-ink);
    border-radius: 20px;
    display: block;
  }
  .scrubhat-about__story h2 {
    font-family: var(--sh-font-heading) !important;
    font-size: 4.4rem;
    line-height: 1.2;
    margin: 0 0 2.4rem;
    color: var(--sh-text);
  }
  .scrubhat-about__story-text {
    font-size: 1.8rem;
    line-height: 1.7;
  }
  .scrubhat-about__story-text p {
    margin: 0 0 2rem;
  }
  .scrubhat-about__note {
    display: inline-block;
    background: var(--sh-pink);
    border: 2px solid var(--sh-ink);
    border-radius: 16px;
    padding: 2rem 2.6rem;
    margin-top: 1rem;
  }
  .scrubhat-about__note-title {
    font-family: var(--sh-font-heading);
    font-size: 2.2rem;
    margin: 0 0 0.4rem;
  }
  .scrubhat-about__note-sub {
    font-size: 1.6rem;
    color: var(--sh-ink);
    margin: 0;
  }
  /* --- Values band --- */
  .scrubhat-about__values {
    background: var(--sh-pink);
    border-radius: 40px;
    max-width: calc(var(--page-width) + 100px);
    margin: 2rem auto;
    padding: 7rem 4rem;
    text-align: center;
  }
  .scrubhat-about__values h2 {
    font-family: var(--sh-font-heading) !important;
    font-size: 4rem;
    letter-spacing: -0.04em;
    margin: 0 0 1rem;
    color: var(--sh-text);
  }
  .scrubhat-about__values-sub {
    font-size: 1.5rem;
    color: #43786c;
    margin: 0 0 5rem;
  }
  .scrubhat-about__values-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 4rem 3rem;
  }
  .scrubhat-about__value {
    width: 220px;
  }
  .scrubhat-about__value-icon {
    width: 56px;
    height: 56px;
    border: 2px solid var(--sh-ink);
    border-radius: 50%;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.4rem;
    margin: 0 auto 1.4rem;
  }
  .scrubhat-about__value h3 {
    font-family: var(--sh-font-body) !important;
    font-weight: 600;
    font-size: 1.8rem;
    margin: 0 0 0.8rem;
    color: var(--sh-text);
  }
  .scrubhat-about__value p {
    font-size: 1.4rem;
    line-height: 1.5;
    margin: 0;
  }
  /* --- Team --- */
  .scrubhat-about__team {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 8rem 2rem 6rem;
    text-align: center;
  }
  .scrubhat-about__team h2 {
    font-family: var(--sh-font-heading) !important;
    font-size: 4.4rem;
    margin: 0 0 1rem;
    color: var(--sh-text);
  }
  .scrubhat-about__team-sub {
    font-size: 1.6rem;
    color: #43786c;
    margin: 0 0 4.5rem;
  }
  .scrubhat-about__team-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2.4rem;
  }
  .scrubhat-about__member {
    width: 200px;
    border: 2px solid var(--sh-ink);
    border-radius: 16px;
    padding: 2.2rem 1.8rem;
  }
  .scrubhat-about__member--mint { background: var(--sh-mint-light); }
  .scrubhat-about__member--pink { background: var(--sh-pink); }
  .scrubhat-about__member-emoji {
    font-size: 3.2rem;
    line-height: 1;
    display: block;
    margin-bottom: 1rem;
  }
  .scrubhat-about__member h3 {
    font-family: var(--sh-font-heading) !important;
    font-size: 1.8rem;
    margin: 0 0 0.4rem;
    color: var(--sh-text);
  }
  .scrubhat-about__member-role {
    font-family: var(--sh-font-body);
    font-weight: 600;
    font-size: 1.3rem;
    color: #43786c;
    margin: 0 0 0.8rem;
  }
  .scrubhat-about__member-text {
    font-size: 1.3rem;
    line-height: 1.5;
    opacity: 0.8;
    margin: 0;
  }
  /* --- CTA --- */
  .scrubhat-about__cta {
    text-align: center;
    padding: 6rem 2rem 8rem;
  }
  .scrubhat-about__cta h2 {
    font-family: var(--sh-font-heading) !important;
    font-size: 4.4rem;
    margin: 0 0 1.6rem;
    color: var(--sh-text);
  }
  .scrubhat-about__cta p {
    font-size: 1.8rem;
    line-height: 1.6;
    max-width: 50rem;
    margin: 0 auto 3rem;
  }
  .scrubhat-about__cta-buttons {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .scrubhat-about__cta .button--mint { background: var(--sh-mint-light); }
  .scrubhat-about__cta .button--pink { background: var(--sh-pink); }
  @media screen and (max-width: 749px) {
    .scrubhat-about__hero-inner,
    .scrubhat-about__story {
      grid-template-columns: 1fr;
      gap: 4rem;
      padding: 0 1rem;
    }
    .scrubhat-about__story {
      padding: 5rem 2rem;
    }
    .scrubhat-about__hero h1 { font-size: 3.8rem; }
    .scrubhat-about__story h2, .scrubhat-about__team h2, .scrubhat-about__cta h2 { font-size: 3rem; }
    .scrubhat-about__values { border-radius: 24px; margin: 1rem; padding: 5rem 2rem; }
    .scrubhat-about__values h2 { font-size: 2.8rem; }
    .scrubhat-about__photo-frame { justify-self: center; max-width: 300px; }
    .scrubhat-about__member { width: 100%; max-width: 320px; }
  }
{% endstyle %}

<div class="scrubhat-about">
  <div class="scrubhat-about__hero">
    <div class="scrubhat-about__hero-inner">
      <div>
        <p class="scrubhat-about__eyebrow">{{ section.settings.hero_eyebrow }}</p>
        <h1>{{ section.settings.hero_heading }}</h1>
        <p class="scrubhat-about__hero-text">{{ section.settings.hero_text }}</p>
        {%- if section.settings.hero_button != blank -%}
          <a href="#scrubhat-story" class="button">{{ section.settings.hero_button }}</a>
        {%- endif -%}
      </div>
      <div class="scrubhat-about__photo-frame">
        {%- if section.settings.hero_image != blank -%}
          {{ section.settings.hero_image | image_url: width: 800 | image_tag: loading: 'eager', alt: 'The Scrub Hat Shop' }}
        {%- else -%}
          <img src="{{ 'scrubhat-about-sewing.png' | asset_url }}" alt="Scrub hat being sewn" width="380" height="380" loading="eager">
        {%- endif -%}
      </div>
    </div>
  </div>

  <div class="scrubhat-about__story" id="scrubhat-story">
    <div class="scrubhat-about__story-photo">
      {%- if section.settings.story_image != blank -%}
        {{ section.settings.story_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: 'Our story' }}
      {%- else -%}
        <img src="{{ 'scrubhat-about-sarah.jpg' | asset_url }}" alt="Sarah, founder of The Scrub Hat Shop" width="450" height="507" loading="lazy">
      {%- endif -%}
    </div>
    <div>
      <p class="scrubhat-about__eyebrow">{{ section.settings.story_eyebrow }}</p>
      <h2>{{ section.settings.story_heading }}</h2>
      <div class="scrubhat-about__story-text">{{ section.settings.story_text }}</div>
      {%- if section.settings.note_title != blank -%}
        <div class="scrubhat-about__note">
          <p class="scrubhat-about__note-title">{{ section.settings.note_title }}</p>
          <p class="scrubhat-about__note-sub">{{ section.settings.note_sub }}</p>
        </div>
      {%- endif -%}
    </div>
  </div>

  <div class="scrubhat-about__values">
    <h2>{{ section.settings.values_heading }}</h2>
    <p class="scrubhat-about__values-sub">{{ section.settings.values_sub }}</p>
    <div class="scrubhat-about__values-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'value' -%}
          <div class="scrubhat-about__value" {{ block.shopify_attributes }}>
            <span class="scrubhat-about__value-icon" aria-hidden="true">{{ block.settings.emoji }}</span>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <div class="scrubhat-about__team">
    <h2>{{ section.settings.team_heading }}</h2>
    <p class="scrubhat-about__team-sub">{{ section.settings.team_sub }}</p>
    <div class="scrubhat-about__team-grid">
      {%- assign member_index = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'member' -%}
          {%- assign color_cycle = member_index | modulo: 2 -%}
          <div
            class="scrubhat-about__member scrubhat-about__member--{% if color_cycle == 0 %}mint{% else %}pink{% endif %}"
            {{ block.shopify_attributes }}
          >
            <span class="scrubhat-about__member-emoji" aria-hidden="true">{{ block.settings.emoji }}</span>
            {%- if block.settings.name != blank -%}
              <h3>{{ block.settings.name }}</h3>
            {%- endif -%}
            <p class="scrubhat-about__member-role">{{ block.settings.role }}</p>
            <p class="scrubhat-about__member-text">{{ block.settings.text }}</p>
          </div>
          {%- assign member_index = member_index | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <div class="scrubhat-about__cta">
    <h2>{{ section.settings.cta_heading }}</h2>
    <p>{{ section.settings.cta_text }}</p>
    <div class="scrubhat-about__cta-buttons">
      {%- if section.settings.cta_button_1 != blank -%}
        <a href="{{ section.settings.cta_link_1 | default: routes.all_products_collection_url }}" class="button button--mint">
          {{ section.settings.cta_button_1 }}
        </a>
      {%- endif -%}
      {%- if section.settings.cta_button_2 != blank -%}
        <a href="{{ section.settings.cta_link_2 | default: '/pages/contact' }}" class="button button--pink">
          {{ section.settings.cta_button_2 }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Scrubhat About",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "hero_eyebrow", "label": "Eyebrow", "default": "— A little bit about us" },
    {
      "type": "inline_richtext",
      "id": "hero_heading",
      "label": "Heading",
      "info": "Use italics for the green words",
      "default": "Hi everyone, <em>we're The<\/em> Scrub Hat Shop!"
    },
    {
      "type": "text",
      "id": "hero_text",
      "label": "Text",
      "default": "Making lightweight, cool and comfortable scrub hats for healthcare heroes all over the world — since 2019."
    },
    { "type": "text", "id": "hero_button", "label": "Button label", "default": "Read our story" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" },
    { "type": "header", "content": "Story" },
    { "type": "text", "id": "story_eyebrow", "label": "Eyebrow", "default": "— Our story" },
    {
      "type": "text",
      "id": "story_heading",
      "label": "Heading",
      "default": "From the operating theatre to your head!"
    },
    {
      "type": "richtext",
      "id": "story_text",
      "label": "Text",
      "default": "<p>My name is <strong>Sarah<\/strong> and I am a retired Veterinary Nurse from Surrey, UK. I set up The Scrub Hat Shop in 2019, and since then it has gone from strength to strength — with people buying our hats all over the world.<\/p><p>I was a Vet Nurse for over <strong>15 years<\/strong> and spent most of my time in orthopaedic and spinal surgeries. I know what it feels like to spend long days in theatre, which is why it was so important to me to create hats that were <strong>lightweight, cool and comfortable ALL day<\/strong> (and look awesome doing it!).<\/p><p>If you don't see a pattern you like or want to ask a question then feel free to contact us — we're a very friendly bunch!<\/p>"
    },
    { "type": "image_picker", "id": "story_image", "label": "Story image" },
    { "type": "text", "id": "note_title", "label": "Note card title", "default": "Happy Scrubbing! 🐾" },
    { "type": "text", "id": "note_sub", "label": "Note card subtitle", "default": "— Sarah and The Team" },
    { "type": "header", "content": "Values band" },
    {
      "type": "inline_richtext",
      "id": "values_heading",
      "label": "Heading",
      "default": "We care for our products, you and the planet"
    },
    {
      "type": "text",
      "id": "values_sub",
      "label": "Subtext",
      "default": "— And therefore, all of our products are made with that in mind."
    },
    { "type": "header", "content": "Team" },
    { "type": "text", "id": "team_heading", "label": "Heading", "default": "Meet the team" },
    {
      "type": "text",
      "id": "team_sub",
      "label": "Subtext",
      "default": "— The wonderful people who make every hat possible"
    },
    { "type": "header", "content": "Call to action" },
    { "type": "text", "id": "cta_heading", "label": "Heading", "default": "Ready to find your perfect scrub hat?" },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Text",
      "default": "Browse our colourful collection of lightweight, comfortable hats — or contact us to design a custom piece just for you."
    },
    { "type": "text", "id": "cta_button_1", "label": "Button 1 label", "default": "Browse hats" },
    { "type": "url", "id": "cta_link_1", "label": "Button 1 link" },
    { "type": "text", "id": "cta_button_2", "label": "Button 2 label", "default": "Contact us" },
    { "type": "url", "id": "cta_link_2", "label": "Button 2 link" }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        { "type": "text", "id": "emoji", "label": "Emoji", "default": "🤍" },
        { "type": "text", "id": "title", "label": "Title", "default": "Made with love" },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Every hat is crafted with genuine care by our team in Surrey, UK."
        }
      ]
    },
    {
      "type": "member",
      "name": "Team member",
      "settings": [
        { "type": "text", "id": "emoji", "label": "Emoji", "default": "🐾" },
        { "type": "text", "id": "name", "label": "Name", "default": "Sarah" },
        { "type": "text", "id": "role", "label": "Role", "default": "Founder & Designer" },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Retired Vet Nurse of 15+ years. Knows exactly what theatre teams need."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scrubhat About"
    }
  ]
}
{% endschema %}
