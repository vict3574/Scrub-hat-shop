{{ 'scrubhat.css' | asset_url | stylesheet_tag }}

{% style %}
  .scrubhat-reviews__band {
    position: relative;
    background: #d9f2ee;
    text-align: center;
    padding: 5rem 2rem 7rem;
  }
  .scrubhat-reviews__badge {
    display: inline-block;
    font-family: var(--sh-font-body);
    font-weight: 600;
    font-size: 1.2rem;
    background: #fffbe8;
    border: 1.5px solid var(--sh-ink);
    border-radius: 99px;
    padding: 0.5rem 1.4rem;
    margin-bottom: 1.6rem;
  }
  .scrubhat-reviews__band h1 {
    font-family: var(--sh-font-heading) !important;
    font-size: 4rem;
    letter-spacing: -0.04em;
    color: var(--sh-text);
    margin: 0 0 1.2rem;
  }
  .scrubhat-reviews__band p {
    font-family: var(--sh-font-body);
    font-size: 1.5rem;
    line-height: 1.5;
    color: var(--sh-text);
    max-width: 34rem;
    margin: 0 auto;
  }
  .scrubhat-reviews__grid {
    max-width: 96rem;
    margin: 0 auto;
    padding: 5rem 2rem 6rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }
  .scrubhat-review-card {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 3px 14px rgba(18, 18, 18, 0.08);
    display: flex;
    flex-direction: column;
  }
  .scrubhat-review-card__photo {
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }
  .scrubhat-review-card__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .scrubhat-review-card__body {
    padding: 2.4rem 2.6rem 2.2rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    font-family: var(--sh-font-body);
  }
  .scrubhat-review-card--pink .scrubhat-review-card__body { background: var(--sh-pink); }
  .scrubhat-review-card--mint .scrubhat-review-card__body { background: var(--sh-mint-light); }
  .scrubhat-review-card__stars {
    color: #35544c;
    font-size: 1.8rem;
    letter-spacing: 0.35em;
    margin: 0 0 1rem;
  }
  .scrubhat-review-card__quote {
    width: 22px;
    height: 21px;
    margin-bottom: 1rem;
  }
  .scrubhat-review-card__title {
    font-weight: 600;
    font-size: 1.7rem;
    color: var(--sh-text);
    margin: 0 0 0.8rem;
  }
  .scrubhat-review-card__text {
    font-size: 1.4rem;
    line-height: 1.6;
    color: var(--sh-text);
    margin: 0 0 1.8rem;
  }
  .scrubhat-review-card__author {
    margin-top: auto;
    border-top: 1px solid rgba(18, 18, 18, 0.12);
    padding-top: 1.4rem;
    font-weight: 600;
    font-size: 1.3rem;
    color: var(--sh-text);
  }
  .scrubhat-review-card__author::before {
    content: '•';
    color: #43786c;
    margin-right: 0.7rem;
  }
  @media screen and (max-width: 749px) {
    .scrubhat-reviews__grid {
      grid-template-columns: 1fr;
      padding: 3rem 1.5rem 4rem;
    }
    .scrubhat-reviews__band h1 {
      font-size: 3rem;
    }
  }
{% endstyle %}

<div class="scrubhat-reviews">
  <div class="scrubhat-reviews__band">
    {%- if section.settings.badge != blank -%}
      <span class="scrubhat-reviews__badge">{{ section.settings.badge }}</span>
    {%- endif -%}
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.subtext }}</p>
  </div>

  <div class="scrubhat-reviews__grid">
    {%- assign fallbacks = 'scrubhat-review-1.jpg,scrubhat-review-2.jpg,scrubhat-review-3.jpg,scrubhat-review-4.jpg'
      | split: ','
    -%}
    {%- for block in section.blocks -%}
      {%- assign fb_index = forloop.index0 | modulo: 4 -%}
      <div class="scrubhat-review-card scrubhat-review-card--{{ block.settings.color }}" {{ block.shopify_attributes }}>
        <div class="scrubhat-review-card__photo">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', alt: block.settings.title }}
          {%- else -%}
            <img src="{{ fallbacks[fb_index] | asset_url }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="450" height="450">
          {%- endif -%}
        </div>
        <div class="scrubhat-review-card__body">
          <p class="scrubhat-review-card__stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</p>
          {%- if block.settings.color == 'mint' -%}
            {%- assign quote_asset = 'scrubhat-quote-mint.svg' -%}
          {%- else -%}
            {%- assign quote_asset = 'scrubhat-quote-pink.svg' -%}
          {%- endif -%}
          <img src="{{ quote_asset | asset_url }}" alt="" class="scrubhat-review-card__quote" width="22" height="21" aria-hidden="true">
          <h2 class="scrubhat-review-card__title">{{ block.settings.title }}</h2>
          <p class="scrubhat-review-card__text">{{ block.settings.text }}</p>
          <p class="scrubhat-review-card__author">{{ block.settings.author }}</p>
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Scrubhat Reviews",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge", "default": "Verified Reviews 🧢" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our customers say" },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Don't just take our word for it — hear from our happy customers!"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Photo" },
        {
          "type": "select",
          "id": "color",
          "label": "Card colour",
          "options": [
            { "value": "pink", "label": "Pink" },
            { "value": "mint", "label": "Mint" }
          ],
          "default": "pink"
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Love the pattern!" },
        { "type": "textarea", "id": "text", "label": "Review text" },
        { "type": "text", "id": "author", "label": "Author", "default": "Happy customer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scrubhat Reviews"
    }
  ]
}
{% endschema %}
