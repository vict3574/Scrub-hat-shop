{{ 'scrubhat.css' | asset_url | stylesheet_tag }}

{% style %}
  .scrubhat-faq {
    background: #f0faf8;
    padding-bottom: 6rem;
  }
  .scrubhat-faq__hero {
    background: #9dd6cf;
    text-align: center;
    padding: 5.6rem 2.4rem 8rem;
  }
  .scrubhat-faq__hero h1 {
    font-family: var(--sh-font-heading) !important;
    font-size: 4.8rem;
    color: #fff;
    margin: 0 0 1.6rem;
    letter-spacing: -0.02em;
  }
  .scrubhat-faq__hero p {
    font-family: var(--sh-font-body);
    font-size: 2rem;
    color: #fff;
    max-width: 46rem;
    margin: 0 auto;
    line-height: 1.5;
  }
  .scrubhat-faq__list {
    max-width: 68rem;
    margin: -3rem auto 0;
    padding: 6rem 2rem 0;
    display: flex;
    flex-direction: column;
    gap: 1.8rem;
  }
  .scrubhat-faq__item {
    background: #fff;
    border: 1px solid #9dd6cf;
    border-radius: 16px;
    box-shadow: 0 2px 8px rgba(45, 141, 126, 0.06);
  }
  .scrubhat-faq__item summary {
    display: flex;
    align-items: flex-start;
    gap: 1.6rem;
    padding: 2.2rem 2.4rem;
    cursor: pointer;
    list-style: none;
  }
  .scrubhat-faq__item summary::-webkit-details-marker {
    display: none;
  }
  .scrubhat-faq__toggle {
    flex-shrink: 0;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: #5bc4b8;
    position: relative;
    margin-top: 0.2rem;
  }
  .scrubhat-faq__toggle::before,
  .scrubhat-faq__toggle::after {
    content: '';
    position: absolute;
    background: #fff;
    border-radius: 2px;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
  }
  .scrubhat-faq__toggle::before {
    width: 12px;
    height: 2.5px;
  }
  .scrubhat-faq__toggle::after {
    width: 2.5px;
    height: 12px;
    transition: opacity 0.15s ease;
  }
  .scrubhat-faq__item[open] .scrubhat-faq__toggle::after {
    opacity: 0;
  }
  .scrubhat-faq__tag {
    display: inline-block;
    font-family: var(--sh-font-body);
    font-weight: 600;
    font-size: 1.1rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 99px;
    padding: 0.4rem 1rem;
    margin-bottom: 0.8rem;
  }
  .scrubhat-faq__tag--mint { background: #d6f0ec; color: #2a8c7e; }
  .scrubhat-faq__tag--pink { background: #fde8f4; color: #c0548a; }
  .scrubhat-faq__tag--yellow { background: #fff3d6; color: #b07a1a; }
  .scrubhat-faq__tag--purple { background: #e8e8fb; color: #5c5cbf; }
  .scrubhat-faq__question {
    font-family: var(--sh-font-body);
    font-weight: 600;
    font-size: 1.7rem;
    color: #2d2d2d;
    margin: 0;
  }
  .scrubhat-faq__answer {
    font-family: var(--sh-font-body);
    font-size: 1.6rem;
    line-height: 1.6;
    color: #4a4a4a;
    padding: 0 2.4rem 2.4rem 6.6rem;
  }
  .scrubhat-faq__answer p {
    margin: 0 0 1rem;
  }
  .scrubhat-faq__cta {
    max-width: 68rem;
    margin: 3rem auto 0;
    padding: 0 2rem;
  }
  .scrubhat-faq__cta-inner {
    background: #fde8f4;
    border-radius: 16px;
    padding: 2.4rem 2.8rem;
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .scrubhat-faq__cta-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #efb3d5;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 2rem;
  }
  .scrubhat-faq__cta-text {
    flex: 1;
    min-width: 20rem;
  }
  .scrubhat-faq__cta-text h2 {
    font-family: var(--sh-font-body) !important;
    font-weight: 600;
    font-size: 1.9rem;
    color: #c0548a;
    letter-spacing: 0;
    margin: 0 0 0.4rem;
  }
  .scrubhat-faq__cta-text p {
    font-family: var(--sh-font-body);
    font-size: 1.4rem;
    color: #c0548a;
    margin: 0;
    line-height: 1.5;
  }
  .scrubhat-faq__cta .button {
    background: #c0548a;
    color: #fff;
    border: none;
    box-shadow: none;
    border-radius: 10px;
    font-family: var(--sh-font-body);
    font-weight: 600;
    font-size: 1.5rem;
  }
  .scrubhat-faq__cta .button:hover {
    transform: none;
    box-shadow: none;
    opacity: 0.9;
  }
  @media screen and (max-width: 749px) {
    .scrubhat-faq__hero h1 {
      font-size: 3.4rem;
    }
    .scrubhat-faq__hero p {
      font-size: 1.6rem;
    }
    .scrubhat-faq__answer {
      padding-left: 2.4rem;
    }
  }
{% endstyle %}

<div class="scrubhat-faq">
  <div class="scrubhat-faq__hero">
    <h1>{{ section.settings.heading }}</h1>
    {%- if section.settings.subtext != blank -%}
      <p>{{ section.settings.subtext }}</p>
    {%- endif -%}
  </div>

  <div class="scrubhat-faq__list">
    {%- for block in section.blocks -%}
      <details class="scrubhat-faq__item" {% if block.settings.open %}open{% endif %} {{ block.shopify_attributes }}>
        <summary>
          <span class="scrubhat-faq__toggle" aria-hidden="true"></span>
          <span>
            {%- if block.settings.tag != blank -%}
              <span class="scrubhat-faq__tag scrubhat-faq__tag--{{ block.settings.tag_color }}">
                {{- block.settings.tag -}}
              </span>
            {%- endif -%}
            <span class="scrubhat-faq__question">{{ block.settings.question }}</span>
          </span>
        </summary>
        <div class="scrubhat-faq__answer">{{ block.settings.answer }}</div>
      </details>
    {%- endfor -%}
  </div>

  {%- if section.settings.cta_heading != blank -%}
    <div class="scrubhat-faq__cta">
      <div class="scrubhat-faq__cta-inner">
        <span class="scrubhat-faq__cta-icon" aria-hidden="true">&#128488;</span>
        <div class="scrubhat-faq__cta-text">
          <h2>{{ section.settings.cta_heading }}</h2>
          <p>{{ section.settings.cta_text }}</p>
        </div>
        <a href="{{ section.settings.cta_link | default: '/pages/contact' }}" class="button">
          {{ section.settings.cta_button | default: 'Message us' }}
        </a>
      </div>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Scrubhat FAQ",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FAQs"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Check out our most frequently asked questions below — and if you don't see what you need, just message us!"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "CTA heading",
      "default": "Still got a question?"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA text",
      "default": "We're always happy to help — drop us a message and we'll get back to you as soon as possible!"
    },
    {
      "type": "text",
      "id": "cta_button",
      "label": "CTA button label",
      "default": "Message us"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "tag",
          "label": "Category tag",
          "default": "Fit & sizing"
        },
        {
          "type": "select",
          "id": "tag_color",
          "label": "Tag colour",
          "options": [
            { "value": "mint", "label": "Mint" },
            { "value": "pink", "label": "Pink" },
            { "value": "yellow", "label": "Yellow" },
            { "value": "purple", "label": "Purple" }
          ],
          "default": "mint"
        },
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Are your hats for men and women?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Yes! Our unique design means they will fit both men and women comfortably.</p>"
        },
        {
          "type": "checkbox",
          "id": "open",
          "label": "Open by default",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scrubhat FAQ"
    }
  ]
}
{% endschema %}
