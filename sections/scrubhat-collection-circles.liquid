{{ 'scrubhat.css' | asset_url | stylesheet_tag }}

<div class="scrubhat-circles">
  {%- if section.settings.heading != blank -%}
    <h2 class="scrubhat-section-title">{{ section.settings.heading }}</h2>
  {%- endif -%}
  <div class="scrubhat-circles__grid">
    {%- assign blobs = 'scrubhat-circle-blob-1.svg,scrubhat-circle-blob-2.svg,scrubhat-circle-blob-3.svg' | split: ',' -%}
    {%- assign fallbacks = 'scrubhat-circle-1.png,scrubhat-circle-2.png,scrubhat-circle-3.png' | split: ',' -%}
    {%- for block in section.blocks -%}
      {%- assign blob_index = forloop.index0 | modulo: 3 -%}
      {%- assign collection = block.settings.collection -%}
      {%- assign title = block.settings.title | default: collection.title -%}
      {%- assign image = block.settings.image | default: collection.featured_image -%}
      {%- assign link = block.settings.link | default: collection.url | default: '#' -%}
      <div class="scrubhat-circles__item" {{ block.shopify_attributes }}>
        <h3 class="scrubhat-circles__title">{{ title }}</h3>
        <a href="{{ link }}" class="scrubhat-circles__media" tabindex="-1">
          <img
            src="{{ blobs[blob_index] | asset_url }}"
            alt=""
            class="scrubhat-circles__blob"
            width="258"
            height="305"
            aria-hidden="true"
          >
          {%- if image != blank -%}
            {{
              image
              | image_url: width: 300, height: 300, crop: 'center'
              | image_tag: class: 'scrubhat-circles__image', loading: 'lazy', alt: title
            }}
          {%- else -%}
            <img
              src="{{ fallbacks[blob_index] | asset_url }}"
              alt="{{ title | escape }}"
              class="scrubhat-circles__image"
              width="300"
              height="300"
              loading="lazy"
            >
          {%- endif -%}
        </a>
        <a href="{{ link }}" class="button">
          {{ block.settings.button_label | default: 'Browse' }}
        </a>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Scrubhat Collections",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Browse our collections and fabrics!"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Custom link",
          "info": "Overrides the collection link"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom title",
          "info": "Defaults to the collection title"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image",
          "info": "Defaults to the collection image"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Browse"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Scrubhat Collections",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
